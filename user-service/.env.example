#### User service environment example
# Copy to user-service/.env and set real values before starting

# PostgreSQL connection string (used by user-service)
DATABASE_URL=postgresql://admin:password@localhost:5432/chat_db

# HTTP port
PORT=8081

# JWT secret used for signing tokens (use a strong secret in production)
JWT_SECRET=changeme

# RabbitMQ / AMQP URL used for inter-service messaging
MESSAGE_BROKER_URL=amqp://localhost

# Node environment
NODE_ENV=development
